<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ── Base App Theme ── -->
    <style name="Theme.HomeServ" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/text_on_primary</item>
        <item name="colorSecondary">@color/primary_light</item>
        <item name="colorOnSecondary">@color/primary</item>
        <item name="colorError">@color/error</item>
        <item name="colorOnError">@color/text_on_primary</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:statusBarColor">@color/primary</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">@color/surface</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="colorControlHighlight">#1A1565C0</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.HomeServ.MediumComponent</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.HomeServ.LargeComponent</item>
    </style>

    <!-- ── Splash Theme ── -->
    <style name="Theme.HomeServ.Splash" parent="Theme.HomeServ">
        <item name="android:statusBarColor">@color/primary</item>
        <item name="android:navigationBarColor">@color/primary</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- ── Shape Appearances ── -->
    <style name="ShapeAppearance.HomeServ.MediumComponent" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>

    <style name="ShapeAppearance.HomeServ.LargeComponent" parent="ShapeAppearance.Material3.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>

    <!-- ── Button Styles ── -->
    <style name="Widget.HomeServ.Button.Primary" parent="Widget.Material3.Button">
        <item name="android:minHeight">@dimen/button_height</item>
        <item name="android:textSize">@dimen/text_button_large</item>
        <item name="android:textColor">@color/text_on_primary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textStyle">bold</item>
        <item name="backgroundTint">@color/primary</item>
        <item name="cornerRadius">@dimen/button_radius</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="elevation">2dp</item>
    </style>

    <style name="Widget.HomeServ.Button.Primary.Pill" parent="Widget.HomeServ.Button.Primary">
        <item name="cornerRadius">@dimen/button_radius_pill</item>
    </style>

    <style name="Widget.HomeServ.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:minHeight">@dimen/button_height</item>
        <item name="android:textSize">@dimen/text_button</item>
        <item name="android:textColor">@color/primary</item>
        <item name="strokeColor">@color/primary</item>
        <item name="cornerRadius">@dimen/button_radius</item>
    </style>

    <style name="Widget.HomeServ.Button.Text" parent="Widget.Material3.Button.TextButton">
        <item name="android:textSize">@dimen/text_button</item>
        <item name="android:textColor">@color/primary</item>
    </style>

    <!-- ── Input Styles ── -->
    <style name="Widget.HomeServ.TextInputLayout" parent="Widget.Material3.TextInputLayout.FilledBox">
        <item name="boxBackgroundColor">@color/input_background</item>
        <item name="boxCornerRadiusTopStart">@dimen/input_radius</item>
        <item name="boxCornerRadiusTopEnd">@dimen/input_radius</item>
        <item name="boxCornerRadiusBottomStart">@dimen/input_radius</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/input_radius</item>
        <item name="boxStrokeColor">@color/input_stroke_color</item>
        <item name="hintTextColor">@color/primary</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
    </style>

    <!-- ── Card Styles ── -->
    <style name="Widget.HomeServ.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">@dimen/card_radius</item>
        <item name="cardElevation">@dimen/card_elevation</item>
        <item name="cardBackgroundColor">@color/surface</item>
        <item name="android:focusable">true</item>
        <item name="android:clickable">true</item>
    </style>

    <style name="Widget.HomeServ.Card.Flat" parent="Widget.HomeServ.Card">
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/divider</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <!-- ── Text Styles ── -->
    <style name="TextAppearance.HomeServ.Header" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textSize">@dimen/text_header</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.HomeServ.Header.OnPrimary" parent="TextAppearance.HomeServ.Header">
        <item name="android:textColor">@color/text_on_primary</item>
    </style>

    <style name="TextAppearance.HomeServ.CardTitle" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textSize">@dimen/text_card_title</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextAppearance.HomeServ.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textSize">@dimen/text_body</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="TextAppearance.HomeServ.Label" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:textSize">@dimen/text_label</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <!-- ── Chip Style ── -->
    <style name="Widget.HomeServ.Chip" parent="Widget.Material3.Chip.Filter">
        <item name="android:textSize">@dimen/text_label_medium</item>
        <item name="chipCornerRadius">@dimen/chip_radius</item>
        <item name="chipMinHeight">@dimen/chip_height</item>
        <item name="chipBackgroundColor">@color/chip_bg_selector</item>
        <item name="android:textColor">@color/chip_text_selector</item>
        <item name="checkedIconVisible">false</item>
    </style>

    <!-- ── Bottom Navigation Style ── -->
    <style name="Widget.HomeServ.BottomNavigationView" parent="Widget.Material3.BottomNavigationView">
        <item name="backgroundTint">@color/surface</item>
        <item name="itemIconTint">@color/bottom_nav_selector</item>
        <item name="itemTextColor">@color/bottom_nav_selector</item>
        <item name="elevation">8dp</item>
    </style>

</resources>