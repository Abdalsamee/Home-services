<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_card_rounded"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="32dp">

    <!-- Success icon circle -->
    <FrameLayout
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:background="@drawable/bg_success_circle">

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="center"
            android:src="@android:drawable/checkbox_on_background"
            />

    </FrameLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:fontFamily="sans-serif-medium"
        android:gravity="center"
        android:text="Request Sent!"
        android:textColor="@color/text_primary"
        android:textSize="@dimen/text_header"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:fontFamily="sans-serif"
        android:gravity="center"
        android:lineSpacingMultiplier="1.4"
        android:text="Your service request has been submitted. The provider will contact you shortly."
        android:textColor="@color/text_secondary"
        android:textSize="@dimen/text_body" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="8dp"
        android:background="@color/divider" />

    <!-- Actions -->
    <Button
        android:id="@+id/btnTrackOrder"
        android:layout_width="match_parent"
        android:layout_height="@dimen/button_height"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_button_primary"
        android:fontFamily="sans-serif-medium"
        android:text="View My Orders"
        android:textColor="@color/text_on_primary"
        android:textSize="@dimen/text_button"
        android:textStyle="bold" />

    <Button
        android:id="@+id/btnBackHome"
        android:layout_width="match_parent"
        android:layout_height="@dimen/button_height"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_button_outlined"
        android:fontFamily="sans-serif-medium"
        android:text="Back to Home"
        android:textColor="@color/text_on_primary"
        android:textSize="@dimen/text_button" />

</LinearLayout>