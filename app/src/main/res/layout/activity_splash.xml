<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_primary_gradient">

    <!-- Top-left decorative circle -->
    <View
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_gravity="top|start"
        android:layout_marginStart="-60dp"
        android:layout_marginTop="-60dp"
        android:background="@drawable/bg_splash_circle" />

    <!-- Bottom-right decorative circle -->
    <View
        android:layout_width="250dp"
        android:layout_height="250dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="-80dp"
        android:layout_marginBottom="-80dp"
        android:background="@drawable/bg_splash_circle" />

    <!-- Bottom-left small circle -->
    <View
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="40dp"
        android:layout_marginBottom="120dp"
        android:background="@drawable/bg_splash_circle" />

    <!-- Center content -->
    <LinearLayout
        android:id="@+id/layoutCenter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:alpha="0"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp">

        <!-- Logo card -->
        <androidx.cardview.widget.CardView
            android:layout_width="@dimen/logo_card_size"
            android:layout_height="@dimen/logo_card_size"
            android:layout_marginBottom="28dp"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="@dimen/logo_card_radius"
            app:cardElevation="12dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_gravity="center"
                android:contentDescription="@string/app_name"
                android:src="@drawable/ic_logo" />

        </androidx.cardview.widget.CardView>

        <!-- App name -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.05"
            android:text="@string/app_name"
            android:textColor="@color/text_on_primary"
            android:textSize="@dimen/text_splash_title"
            android:textStyle="bold" />

        <!-- Tagline -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="sans-serif"
            android:letterSpacing="0.03"
            android:text="@string/app_tagline"
            android:textColor="#CCffffff"
            android:textSize="@dimen/text_body" />

    </LinearLayout>

    <!-- Bottom loading indicator -->
    <LinearLayout
        android:id="@+id/layoutBottom"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:alpha="0"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingBottom="64dp">

        <ProgressBar
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:indeterminateTint="@color/text_on_primary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Professional services at your doorstep"
            android:textColor="#99ffffff"
            android:textSize="@dimen/text_label" />

    </LinearLayout>

</FrameLayout>