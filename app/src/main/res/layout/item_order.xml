<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="@dimen/screen_padding_horizontal"
    android:layout_marginEnd="@dimen/screen_padding_horizontal"
    android:layout_marginBottom="@dimen/card_gap"
    android:foreground="?attr/selectableItemBackground"
    app:cardBackgroundColor="@color/surface"
    app:cardCornerRadius="@dimen/card_radius"
    app:cardElevation="3dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/card_padding">

        <!-- Top row: avatar + info + status -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/ivProviderAvatar"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_logo"
                app:civ_border_color="@color/primary_light"
                app:civ_border_width="2dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvProviderName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:maxLines="1"
                    android:text="Provider Name"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_card_title"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvCategoryName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:fontFamily="sans-serif"
                    android:text="Category"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_label" />

            </LinearLayout>

            <!-- Status badge -->
            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_status_badge_dynamic"
                android:fontFamily="sans-serif-medium"
                android:paddingStart="10dp"
                android:paddingTop="4dp"
                android:paddingEnd="10dp"
                android:paddingBottom="4dp"
                android:text="Pending"
                android:textSize="@dimen/text_small" />

        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="@dimen/divider_height"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="12dp"
            android:background="@color/divider" />

        <!-- Details row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- Date -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_marginEnd="4dp"
                    android:src="@android:drawable/ic_menu_my_calendar"
                    app:tint="@color/text_secondary" />

                <TextView
                    android:id="@+id/tvDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif"
                    android:text="2024-01-01"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_label" />

            </LinearLayout>

            <!-- Total price -->
            <TextView
                android:id="@+id/tvTotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="$25.00"
                android:textColor="@color/primary"
                android:textSize="@dimen/text_label_medium"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Address -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_marginEnd="4dp"
                android:src="@android:drawable/ic_menu_mylocation"
                app:tint="@color/text_secondary" />

            <TextView
                android:id="@+id/tvAddress"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="sans-serif"
                android:maxLines="1"
                android:text="123 Main St"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_label" />

        </LinearLayout>

        <!-- Rate button — only shown for completed unrated orders -->
        <Button
            android:id="@+id/btnRate"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_button_outlined"
            android:drawableStart="@android:drawable/star_on"
            android:fontFamily="sans-serif-medium"
            android:text="Rate this Service"
            android:textColor="@color/text_on_primary"
            android:textSize="@dimen/text_label_medium"
            android:visibility="gone" />

        <!-- Already rated row -->
        <LinearLayout
            android:id="@+id/layoutRated"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:visibility="gone">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginEnd="4dp"
                android:src="@android:drawable/star_on"
                app:tint="@color/rating_gold" />

            <TextView
                android:id="@+id/tvRatingGiven"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="You rated: 5 ★"
                android:textColor="@color/rating_gold"
                android:textSize="@dimen/text_label" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>